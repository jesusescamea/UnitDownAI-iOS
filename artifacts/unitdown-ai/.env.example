# Copy this file to .env and fill in the values before running `pnpm build`.
#
# VITE_ variables are embedded into the client bundle at build time.
# They must be present when you run `pnpm build` or `pnpm dev`.

# Clerk publishable key  (starts with pk_live_ for production, pk_test_ for dev)
# Get it from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_key_here
